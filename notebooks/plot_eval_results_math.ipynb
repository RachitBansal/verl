    "                        \"total_step\": pt_step + rl_step,\n",
    "                        \"samples\": k,\n",
    "                        \"temp\": float(rl_match.group(\"temp\")),\n",
    "                        \"score\": score,\n",
    "                        \"path\": str(path),\n",
    "                        \"label\": name,\n",
    "                        \"num_rollouts\": num_rollouts,\n",
    "                    })\n",
    "                break\n",
    "\n",
    "gsm8k_rl_df = pd.DataFrame(gsm8k_rl_rows)\n",
