    "    fig, axes = plt.subplots(n_rollouts, n_samples, figsize=(16, 4 * n_rollouts), sharey=True)\n",
    "    if n_rollouts == 1:\n",
    "        axes = axes.reshape(1, -1)\n",
    "    if n_samples == 1:\n",
